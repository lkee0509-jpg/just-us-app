# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── TWILIO WHATSAPP ─────────────────────────────────────────────────────────
# Get these from: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# For sandbox testing, use this number. For production, change to your number.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── OPENWEATHER ─────────────────────────────────────────────────────────────
# Get free key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_key_here

# ─── GNEWS ───────────────────────────────────────────────────────────────────
# Get free key from: https://gnews.io
GNEWS_API_KEY=your_gnews_key_here

# ─── ANTHROPIC (for daily song suggestions) ──────────────────────────────────
# Get key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# ─── SECURITY ────────────────────────────────────────────────────────────────
# Make up any random string (e.g., type random letters). Protects your cron job.
CRON_SECRET=make_up_anything_random_here

# ─── INVITE CODE ─────────────────────────────────────────────────────────────
# Only people with this code can create an account. Share only with your friend.
NEXT_PUBLIC_INVITE_CODE=our-secret-code
